# Polymarket Algo Trader — Environment Variables
# Copy this to .env and fill in your values

# Trading Mode: paper | shadow | live
TRADING_MODE=paper

# Polymarket Wallet (only needed for live mode)
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=

# Claude API (optional — enables News-to-Price Latency strategy)
ANTHROPIC_API_KEY=

# Risk Limits
MAX_POSITION_USD=50
MAX_EXPOSURE_USD=500

# Server
PORT=8000
LOG_LEVEL=INFO
